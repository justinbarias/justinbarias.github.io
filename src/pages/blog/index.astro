---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Writing — Justin Barias';
const description = 'Essays on evals, agents, AI platforms, and distributed systems.';
const permalink = `${Astro.site?.href}blog`;

let allPosts = await getCollection('posts')
allPosts = allPosts.sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());
---

<BaseLayout title={title} description={description} permalink={permalink} current="blog">
  <div class="blog-head">
    <h1>Writing</h1>
    <p class="blog-sub">{allPosts.length} essays on evals, agents &amp; AI platforms</p>
  </div>
  <div class="container">
    <ul class="post-list">
      {allPosts.map((post) => {
        const href = `/blog/${post.data.slug}`;
        return (
          <li class="post-item">
            <span class="post-date">{post.data.publishDate}</span>
            <h2><a href={href}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
          </li>
        )
      })}
    </ul>
  </div>
</BaseLayout>
