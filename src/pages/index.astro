import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Justin Barias — Lead Software & AI Engineer';
const description = 'Justin Barias builds evaluation-based AI and AIOps platforms. Software, AI, distributed systems, and the writing in between.';
