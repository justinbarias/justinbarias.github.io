              <stop offset="60%" stop-color="var(--accent-2)" />
              <stop offset="100%" stop-color="var(--hot)" />
            </linearGradient>
          </defs>
          <g stroke="var(--rule)" stroke-width="1">
            <line x1="0" y1="60" x2="400" y2="60" />
            <line x1="0" y1="120" x2="400" y2="120" />
            <line x1="0" y1="180" x2="400" y2="180" />
          </g>
