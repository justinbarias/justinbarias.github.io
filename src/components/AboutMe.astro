  </section>

  <!-- ============ SPEAKING ============ -->
  <section class="section speaking" id="speaking">
    <div class="sec-head">
      <span class="sec-label skin-only" data-skin-only="quiet"><span class="num">05</span> &mdash; Speaking</span>
      <span class="sec-label skin-only" data-skin-only="terminal">$ cat talks.log</span>
      <span class="sec-label skin-only" data-skin-only="descent">// speaking &middot; talks</span>
    </div>
    <ol class="talk-list">
      {talks.map((t) => (
        <li class="talk">
          <div class="talk-when">{t.date}</div>
          <div class="talk-what">
            <h3 class="talk-title">
              {t.href ? (
                <a href={t.href} target="_blank" rel="noopener noreferrer">{t.title}</a>
              ) : (
                t.title
              )}
            </h3>
            <p class="talk-venue">{t.venue}{t.note ? ` · ${t.note}` : ''}</p>
            {t.links && (
              <div class="talk-links">
                {t.links.map((l) => (
                  <a class="talk-link" href={l.href} target="_blank" rel="noopener noreferrer">
                    {l.label} &rarr;{l.note && <span class="talk-link-note"> · {l.note}</span>}
                  </a>
                ))}
              </div>
            )}
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- ============ SKILLS ============ -->
  <section class="section skills-section" id="skills">
    <div class="sec-head">
      <span class="sec-label skin-only" data-skin-only="quiet"><span class="num">06</span> &mdash; Skills</span>
      <span class="sec-label skin-only" data-skin-only="terminal">$ ./skills --list</span>
      <span class="sec-label skin-only" data-skin-only="descent">// skills &middot; metrics</span>
    </div>
    <ul class="skills">
      {skills.map((s) => (
        <li class="skill" data-score={s.score}>
          <span class="skill-icon" set:html={skillIcons[s.icon]} />
          <span class="skill-name">{s.name}</span>
          <span class="skill-desc">{s.description}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ============ CONTACT ============ -->
  <section class="section contact" id="contact">
    <div class="sec-head">
      <span class="sec-label skin-only" data-skin-only="quiet"><span class="num">07</span> &mdash; Say hello</span>
      <span class="sec-label skin-only" data-skin-only="terminal">$ ./contact</span>
      <span class="sec-label skin-only" data-skin-only="descent">// contact</span>
    </div>
    <ul class="contact-list">
      {contacts.map((c) => (
        <li>
          <a class="contact-link" href={c.href} {...(c.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
            <span class="c-label">{c.label}</span>
            <span class="c-value">{c.value}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</div>

<script is:inline>
  (function () {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // --- Terminal hero: type the role line ---
    let typing = null;
    function typeRole() {
      const el = document.querySelector('.js-type');
      if (!el) return;
      const text = el.getAttribute('data-text') || '';
      if (reduce) {
        el.textContent = text;
        return;
      }
      if (typing) clearInterval(typing);
      el.textContent = '';
      let i = 0;
      typing = setInterval(() => {
        el.textContent = text.slice(0, ++i);
        if (i >= text.length) {
          clearInterval(typing);
          typing = null;
        }
      }, 38);
    }

    // --- Descent hero: redraw the loss path on demand ---
    function drawLoss() {
      const path = document.querySelector('.loss-path');
      if (!path || reduce) return;
      const len = path.getTotalLength();
      path.style.transition = 'none';
      path.style.strokeDasharray = len;
      path.style.strokeDashoffset = len;
      path.getBoundingClientRect();
      path.style.transition = 'stroke-dashoffset 1.7s ease';
      path.style.strokeDashoffset = '0';
    }

    function runForSkin() {
      const skin = document.documentElement.dataset.skin;
      if (skin === 'terminal') typeRole();
      if (skin === 'descent') drawLoss();
    }

    runForSkin();
    window.addEventListener('skinchange', runForSkin);
    document.addEventListener('astro:after-swap', runForSkin);
  })();
</script>
