      <p class="hero-eyebrow">Lead Software &amp; AI Engineer</p>
      <h1 class="hero-name">
        <span class="hn-line">Justin</span>
        <span class="hn-line">Barias<span class="hn-dot">.</span></span>
      </h1>
      <p class="hero-tagline">
        I build the platforms, tooling, and practices that take AI agents from experiment to production.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/blog">Read the writing</a>
        <a class="btn" href="#contact">Get in touch</a>
      </div>
    </div>

    <!-- terminal -->
    <div class="hero-terminal skin-only" data-skin-only="terminal">
      <div class="term-window">
        <div class="term-bar">
          <span class="term-dot"></span><span class="term-dot"></span><span class="term-dot"></span>
          <span class="term-title">justin@dewr: ~</span>
        </div>
        <div class="term-body">
          <div class="term-line"><span class="term-prompt">whoami</span></div>
          <div class="term-line"><span class="term-out">&gt; <span class="js-type" data-text={roleText}>{roleText}</span><span class="caret"></span></span></div>
          <div class="term-line">&nbsp;</div>
          <div class="term-line"><span class="term-prompt">cat about.md</span></div>
          <div class="term-line"><span class="term-comment"># I take AI agents from experiment to production.</span></div>
          <div class="term-line"><span class="term-comment"># Loop: evaluate &rarr; descend &rarr; ship.</span></div>
        </div>
      </div>
    </div>

    <!-- descent -->
    <div class="hero-descent skin-only" data-skin-only="descent">
      <div class="hero-descent-text">
        <p class="hero-eyebrow">Lead Software &amp; AI Engineer</p>
        <h1 class="hero-name">Justin Barias</h1>
        <p class="hero-tagline">
          I tune platforms the way you tune a model: evaluate, then descend toward the minimum.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/blog">Read the writing</a>
          <a class="btn" href="#contact">Get in touch</a>
        </div>
      </div>
      <div class="chart-wrap" aria-hidden="true">
        <div class="chart-readout">training loss &nbsp;<b id="loss-readout">0.0214</b> &nbsp;·&nbsp; epoch 42</div>
        <svg class="loss-chart" viewBox="0 0 400 240" role="img" aria-label="A loss curve descending to a minimum">
          <defs>
            <linearGradient id="lossGrad" x1="0" y1="0" x2="1" y2="1">
